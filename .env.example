# ─────────────────────────────────────────────────────────────────────────────
# VendorProof environment
# Copy this file to `.env.local` and fill in your keys.
# The app runs in SAMPLE MODE with zero keys, so it always demos.
# ─────────────────────────────────────────────────────────────────────────────

# Exa API key — powers live web diligence. Get one at https://dashboard.exa.ai
# Used SERVER-SIDE ONLY (in the /api/verify route). Never exposed to the client.
# If missing, the app falls back to sample mode (pre-baked Intercom diligence).
EXA_API_KEY=
